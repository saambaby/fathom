# Fathom — required environment variables.
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is excluded by .gitignore (INV-08).

# OANDA v20 API bearer token (from the OANDA developer portal)
OANDA_API_TOKEN=your-oanda-api-token-here

# OANDA account identifier (numeric string, e.g. 101-001-12345678-001)
OANDA_ACCOUNT_ID=your-oanda-account-id-here

# Trading environment: "demo" (default) or "live"
# "demo" targets https://api-fxpractice.oanda.com
# "live" targets https://api-fxtrade.oanda.com
# OANDA_BASE_URL is derived automatically from ENV — you do not need to set it.
ENV=demo
